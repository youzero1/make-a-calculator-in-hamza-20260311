'c' || key === 'C') {
        handleButtonClick('C');
      } else if (key === '.') {
        handleButtonClick('.');
      } else if (key === '%') {
        handleButtonClick('%');
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [handleButtonClick]);

  const buttons = [
    { label: 'C', type: 'action' as const, value: 'C' },
    { label: '±', type: 'action' as const, value: '±' },
    { label: '%', type: 'action' as const, value: '%' },
    { label: '÷', type: 'operator' as const, value: '÷' },
    { label: '7', type: 'number' as const, value: '7' },
    { label: '8', type: 'number' as const, value: '8' },
    { label: '9', type: 'number' as const, value: '9' },
    { label: '×', type: 'operator' as const, value: '×' },
    { label: '4', type: 'number' as const, value: '4' },
    { label: '5', type: 'number' as const, value: '5' },
    { label: '6', type: 'number' as const, value: '6' },
    { label: '-', type: 'operator' as const, value: '-' },
    { label: '1', type: 'number' as const, value: '1' },
    { label: '2', type: 'number' as const, value: '2' },
    { label: '3', type: 'number' as const, value: '3' },
    { label: '+', type: 'operator' as const, value: '+' },
    { label: '⌫', type: 'action' as const, value: '⌫' },
    { label: '0', type: 'number' as const, value: '0' },
    { label: '.', type: 'number' as const, value: '.' },
    { label: '=', type: 'equals' as const, value: '=' },
  ];

  return (
    <div className={styles.container}>
      <div className={styles.calculator}>
        <Display expression={expression} result={displayResult} />
        <div className={styles.grid}>
          {buttons.map((btn) => (
            <Button
              key={btn.label}
              label={btn.label}
              type={btn.type}
              onClick={() => handleButtonClick(btn.value)}
              gridSpan={btn.gridSpan}
            />
          ))}
        </div>
      </div>
      <History
        history={history}
        onClearHistory={clearHistory}
        onSelectCalculation={handleSelectCalculation}
      />
    </div>
  );
};

export default Calculator;
